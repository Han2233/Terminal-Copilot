{
  "manifest_version": 3,
  "name": "Terminal Copilot - POC",
  "description": "AI 终端助手 - 读取 Web 终端内容验证",
  "version": "0.0.3",
  "permissions": [
    "sidePanel",
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://shell.alibaba-inc.com/*",
    "https://*.alibaba-inc.com/*"
  ],
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_title": "Terminal Copilot"
  }
}
